# Copie este ficheiro para ".env" e ajuste os valores antes de arrancar o servidor.

# Chave secreta usada para assinar os tokens de sessão do administrador.
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Password de acesso à área de administração.
ADMIN_PASSWORD=escolha-uma-password-forte

# Nome da instituição (aparece apenas em logs/metadados do backend).
INSTITUTION_NAME=A Sua Instituição

# Porta onde o servidor Flask corre.
PORT=5000

# URL de conexão PostgreSQL. Exemplo:
# postgresql://usuario:senha@localhost:5432/feedback
DATABASE_URL=postgresql://user:password@localhost:5432/feedback
